# MuJoCo Gym OpenEnv — separate HF Space or local runs (heavy optional deps).
# Default Dockerfile stays slim for customer_support_env only.

FROM python:3.11-slim-bookworm

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV PORT=7860

WORKDIR /app

COPY . .

RUN pip install --no-cache-dir --upgrade pip \
  && pip install --no-cache-dir ".[mujoco]"

EXPOSE 7860

CMD ["sh", "-c", "uvicorn mujoco_gym_env.server.app:app --host 0.0.0.0 --port ${PORT:-7860}"]
